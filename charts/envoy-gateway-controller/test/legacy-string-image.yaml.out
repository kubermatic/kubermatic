kind: BackendTrafficPolicy
metadata:
  name: kubermatic-backend-policy
  namespace: default
  labels:
    app.kubernetes.io/name: backend-traffic-policy
    app.kubernetes.io/instance: release-name
    app.kubernetes.io/managed-by: helm
spec:
  targetRefs:
