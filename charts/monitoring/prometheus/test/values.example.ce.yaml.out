---
# Source: prometheus/templates/statefulset.yaml
apiVersion: policy/v1

kind: PodDisruptionBudget
metadata:
  name: 'release-name'
spec:
  minAvailable: 1
  selector:
    matchLabels:
      app: 'release-name'
---
